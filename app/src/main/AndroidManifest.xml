<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Self-hosted in-app update channel — required so the package
         installer can be launched without redirecting through Settings
         every time. The OS still gates first-time grant per-package. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Media3 MediaSessionService must run as a foreground service of type
         mediaPlayback so the OS keeps the audio pipeline alive and shows
         the media notification. POST_NOTIFICATIONS is needed from API 33. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Required so MediaDownloadService's PlatformScheduler can persist
         queued JobScheduler jobs across reboots. Without this the
         scheduler silently downgrades to non-persistent jobs and
         interrupted downloads stall until the user opens the app. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Saving songs as alarm sound writes to MediaStore. Android 10+ uses
         scoped storage (no permission); pre-Q needs the legacy write perm. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Android 11+ package visibility: SpeechRecognizer needs to resolve
         the system voice intent before launching. Without this the search
         screen's mic button silently no-ops on API 30+. -->
    <queries>
        <intent>
            <action android:name="android.speech.action.RECOGNIZE_SPEECH" />
        </intent>
    </queries>

    <application
        android:name=".MediaPlayerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.MediaPlayer"
        tools:targetApi="34">

        <!-- Android Auto discovery. Points at res/xml/automotive_app_desc.xml
             which declares the `media` capability. Inert on non-AA devices. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <meta-data
            android:name="com.google.android.gms.car.notification.SmallIcon"
            android:resource="@mipmap/ic_launcher" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.MediaPlayer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Playlist share deep link — Android App Link over https.
                 Messaging apps (WhatsApp/Telegram/SMS/Gmail) only auto-linkify
                 http(s):// URLs, so the share text must be an https URL or
                 recipients see plain text. `autoVerify=true` makes the system
                 fetch /.well-known/assetlinks.json from the host on install
                 and bind this filter to the app — a verified link opens
                 directly in MainActivity, no chooser. If verification fails
                 the filter still works (with a chooser). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https"
                      android:host="92b70eb3-9758-47a7-a830-744a9d61f809.duckdns.org"
                      android:pathPrefix="/share/" />
            </intent-filter>
            <!-- Back-compat for any `mediaplayer://share/<token>` links already
                 sent before the https switch. Same MainActivity entry point. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="mediaplayer" android:host="share" />
            </intent-filter>
        </activity>

        <!-- Media3 MediaSessionService. The intent filter is what lets the
             system auto-wire lock-screen / notification media controls. -->
        <service
            android:name=".playback.MediaPlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="android.media.browse.MediaBrowserService" />
                <!-- Lets Google Assistant in cars route "Hey Google, play X
                     on MediaPlayer" voice queries to this service. The query
                     surfaces in onSetMediaItems via the
                     MediaItem.RequestMetadata.searchQuery field. -->
                <action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" />
            </intent-filter>
        </service>
        <!-- M13: foreground service for explicit song downloads. -->
        <service
            android:name=".playback.MediaDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync">
            <intent-filter>
                <action android:name="androidx.media3.exoplayer.downloadService.action.RESTART" />
            </intent-filter>
        </service>

        <!-- FileProvider for the self-hosted update channel — exposes the
             downloaded APK to the system package installer with a granted
             read URI permission. Path config in res/xml/file_paths.xml. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
